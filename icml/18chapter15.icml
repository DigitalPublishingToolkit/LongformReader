        <PathGeometry>
          <GeometryPathType PathOpen="false">
            <PathPointArray>
              <PathPointType Anchor="-288.00000 -382.12500" LeftDirection="-288.00000 -382.12500" RightDirection="-288.00000 -382.12500" />
              <PathPointType Anchor="-288.00000 382.12500" LeftDirection="-288.00000 382.12500" RightDirection="-288.00000 382.12500" />
              <PathPointType Anchor="288.00000 382.12500" LeftDirection="288.00000 382.12500" RightDirection="288.00000 382.12500" />
              <PathPointType Anchor="288.00000 -382.12500" LeftDirection="288.00000 -382.12500" RightDirection="288.00000 -382.12500" />
            </PathPointArray>
          </GeometryPathType>
        </PathGeometry>
      </Properties>
      <Image Self="ue6" ItemTransform="1.00000 0 0 1.00000 -288.00000 -382.12500">
