  <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/Bold Italic">
    <Content>Francesco Barchiesi</Content>
  </CharacterStyleRange>
  <CharacterStyleRange AppliedCharacterStyle="$ID/NormalCharacterStyle">
    <Content> </Content>
  </CharacterStyleRange>
  <CharacterStyleRange AppliedCharacterStyle="CharacterStyle/Italic">
    <Content>is a full-time PhD student at the University of Birmingham, currently digging into the world of incel culture. Having spent most of his life in Bologna (Italy) navigating the clouds of Philosophy and Semiotics, his research is essentially an excuse to obsess over digital cultures of the self, the pitfalls of networked intimacy, and the messy transformations of modern love.</Content>
  </CharacterStyleRange>
</ParagraphStyleRange>

